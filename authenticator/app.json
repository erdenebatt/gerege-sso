{
  "expo": {
    "name": "Gerege Authenticator",
    "slug": "gerege-authenticator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a56db"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "QR код скан хийхэд камер ашиглана"
      },
      "bundleIdentifier": "mn.gerege.authenticator"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a56db"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA"],
      "package": "mn.gerege.authenticator"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "QR код скан хийхэд камер ашиглана"
        }
      ]
    ]
  }
}
