%% ============================================================================
%% 1. SYSTEM OVERVIEW - High Level Architecture
%% ============================================================================
%% Gerege SSO нь Монгол улсын иргэдэд зориулсан нэгдсэн нэвтрэлт
%% таниулалтын (OAuth 2.0) систем юм.
%%
%% Дэмждэг нэвтрэлтийн аргууд:
%%   - OAuth 2.0 Social: Google, Apple, Facebook, Twitter/X
%%   - DAN (Цахим иргэний үнэмлэх) SSO
%%   - Email OTP (нууц үггүй нэвтрэлт)
%%   - Утасны OTP баталгаажуулалт
%%   - Регистрийн дугаар (reg_no) баталгаажуулалт (ЗААВАЛ)
%%   - Олон provider-ийн бүртгэл холбох (account linking)
%%   - MFA/2FA: TOTP (Authenticator App), Passkey/FIDO2, Push Notification
%%   - QR Code Login (нууц үггүй нэвтрэлт)
%%   - Recovery Codes (нөөц нэвтрэлтийн код)
%%
%% Tech Stack:
%%   Backend:  Go 1.21+ / Gin framework
%%   Frontend: Next.js 14+ (App Router) / TypeScript / Tailwind CSS
%%   Database: PostgreSQL 15
%%   Cache:    Redis 7
%%   Infra:    Docker Compose / Nginx / Grafana
%% ============================================================================

graph TB
    subgraph "External Identity Providers"
        GOOGLE["Google OAuth2"]
        APPLE["Apple Sign-In"]
        FACEBOOK["Facebook OAuth2"]
        TWITTER["Twitter/X OAuth2<br/>(PKCE)"]
        DAN["DAN SSO<br/>(sso.gov.mn)<br/>Цахим иргэний үнэмлэх"]
    end

    subgraph "Gerege SSO Platform"
        subgraph "Frontend - Next.js 14+ (App Router)"
            LOGIN["Login Page<br/>/"]
            CALLBACK["Callback Handler<br/>/callback"]
            REGISTER["Register Page<br/>/register<br/>(reg_no verification)"]
            CONSENT["OAuth Consent<br/>/consent"]
            DASHBOARD["Dashboard<br/>/dashboard/**"]
            GRANTS_PAGE["Grants<br/>/grants"]
            ADMIN_UI["Admin Panel<br/>/admin/**"]
        end

        subgraph "Backend - Go/Gin :8080"
            AUTH_API["/api/auth/*<br/>Authentication API"]
            OAUTH_API["/api/oauth/*<br/>OAuth2 Server API"]
            ADMIN_API["/api/admin/*<br/>Admin API"]
            MIDDLEWARE["Middleware Stack<br/>JWT | CORS | RateLimit<br/>Logger | Security | Metrics"]
        end

        subgraph "Data Layer"
            POSTGRES[("PostgreSQL 15<br/>Users, Citizens, Clients<br/>Grants, Audit Logs")]
            REDIS[("Redis 7<br/>Sessions, OTP, State<br/>JWT Blacklist, Cache")]
        end
    end

    subgraph "External Services"
        GEREGE_CORE["Gerege Core API<br/>Иргэний бүртгэлийн мэдээлэл"]
        SMTP["SMTP Server<br/>Email OTP илгээх"]
    end

    subgraph "Third-Party Apps (OAuth2 Clients)"
        CLIENT_APP["Client Application<br/>redirect_uri дээр буцаах"]
    end

    GOOGLE --> AUTH_API
    APPLE --> AUTH_API
    FACEBOOK --> AUTH_API
    TWITTER --> AUTH_API
    DAN --> AUTH_API

    LOGIN --> AUTH_API
    CALLBACK --> AUTH_API
    REGISTER --> AUTH_API
    CONSENT --> OAUTH_API
    DASHBOARD --> AUTH_API
    GRANTS_PAGE --> AUTH_API
    ADMIN_UI --> ADMIN_API

    AUTH_API --> MIDDLEWARE
