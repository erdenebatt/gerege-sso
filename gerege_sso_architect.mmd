%% 18. REDIS KEY PATTERNS
%% ============================================================================
%% Redis-д хадгалагдах бүх түлхүүрүүд:
%% ============================================================================

graph TB
    subgraph "Redis Key Patterns"
        R1["oauth_state:{state}<br/>TTL: 10 мин<br/>OAuth state verification"]
        R2["exchange_code:{code}<br/>TTL: 60 сек<br/>Single-use token exchange"]
        R3["email_otp:{email}<br/>TTL: 10 мин<br/>Value: 'OTP:attempt_count'"]
        R4["email_otp_cooldown:{email}<br/>TTL: 60 сек<br/>Дахин илгээх хязгаар"]
        R5["phone_otp:{user_id}<br/>TTL: 5 мин<br/>Value: 'OTP:attempt_count'"]
        R6["phone_otp_cooldown:{user_id}<br/>TTL: 60 сек<br/>Дахин илгээх хязгаар"]
        R7["pending_link:{gen_id}<br/>TTL: 10 мин<br/>Account linking data (JSON)"]
        R8["jwt_blacklist:{jti}<br/>TTL: token expiry хүртэл<br/>Logout хийсэн token"]
        R9["auth_code:{code}<br/>TTL: 5 мин<br/>OAuth2 authorization code"]
        R10["dan_state:{state}<br/>TTL: 10 мин<br/>DAN SSO state"]
        R11["rate_limit:{ip}:{endpoint}<br/>TTL: 1 мин<br/>Token bucket counter"]
        R12["oauth_client:{client_id}<br/>TTL: cache TTL<br/>Client data cache"]
        R13["webauthn_reg:{gen_id}<br/>TTL: 5 мин<br/>WebAuthn бүртгэлийн session"]
        R14["webauthn_auth:{gen_id}<br/>TTL: 5 мин<br/>WebAuthn баталгаажуулалтын session"]
        R15["mfa_totp_setup:{user_id}<br/>TTL: 10 мин<br/>TOTP тохиргооны түр мэдээлэл"]
        R16["qr_session:{session_id}<br/>TTL: 5 мин<br/>QR нэвтрэлтийн session"]
        R17["push_challenge:{challenge_id}<br/>TTL: 60 сек<br/>Push notification challenge"]
    end

