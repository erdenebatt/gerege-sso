    users ||--o{ dan_verification_logs : "user_id"
    users ||--o{ registry_verify_logs : "user_id"
    oauth_clients ||--o{ user_grants : "client_id"
    users ||--o| user_mfa_settings : "user_id"
    users ||--o| user_totp : "user_id"
    users ||--o{ mfa_recovery_codes : "user_id"
    users ||--o{ webauthn_credentials : "user_id"
    users ||--o{ user_devices : "user_id"
    users ||--o{ qr_login_sessions : "approved_user_id"
    users ||--o{ mfa_audit_log : "user_id"

%% ============================================================================
%% 3. OAUTH2 SOCIAL LOGIN FLOW (Google жишээ дээр)
%% ============================================================================
%% Бүх social provider ижил урсгалтай:
%%   1. Frontend → Backend redirect → Provider
%%   2. Provider → Backend callback → Exchange code үүсгэх
%%   3. Frontend → Exchange code → JWT token авах
%%   4. verified=false бол /register руу чиглүүлэх
%% ============================================================================

sequenceDiagram
    participant U as Хэрэглэгч (Browser)
    participant FE as Frontend (Next.js)
    participant BE as Backend (Go/Gin)
    participant G as Google OAuth2
    participant DB as PostgreSQL
    participant R as Redis

    U->>FE: "Google-ээр нэвтрэх" дарах
    FE->>BE: GET /api/auth/google
    BE->>R: state token хадгалах (10 мин TTL)
    BE->>U: 302 Redirect → Google Authorization URL

    U->>G: Google нэвтрэлт хийх
    G->>BE: GET /api/auth/google/callback?code=XXX&state=YYY

    BE->>R: state token шалгах
    BE->>G: Authorization code → Access Token солих
    G-->>BE: Access Token
    BE->>G: GET /userinfo (email, name, picture)
    G-->>BE: User Info

    alt Хэрэглэгч байхгүй бол
        BE->>DB: gen_id үүсгэх (11 оронтой)
        BE->>DB: INSERT users (google_sub, email, verified=false)
    else Хэрэглэгч байвал
        BE->>DB: UPDATE last_login_at
    end

    alt Ижил email-тэй өөр provider-ийн бүртгэл байвал
        BE->>R: pending_link хадгалах (10 мин TTL)
        BE->>U: 302 → /callback?pending_link=true&gen_id=XXX
    else Хэвийн нэвтрэлт
        BE->>R: exchange_code хадгалах (60 сек TTL, нэг удаагийн)
        BE->>U: 302 → /callback?code=EXCHANGE_CODE
    end

    FE->>BE: POST /api/auth/exchange-token {code}
    BE->>R: exchange_code шалгах + устгах

    alt MFA идэвхтэй хэрэглэгч
        BE->>BE: TempJWT үүсгэх (5 мин, хязгаарлагдмал эрх)
        BE-->>FE: {mfa_required: true, temp_token, mfa_methods: [...]}
        FE->>U: /mfa руу чиглүүлэх (MFA challenge хуудас)
    else MFA идэвхгүй хэрэглэгч
        BE->>BE: JWT token үүсгэх (24 цаг)
        BE-->>FE: {token, user}
    end

    FE->>FE: token → localStorage + cookie

    alt user.verified === false
        FE->>U: /register руу чиглүүлэх
    else user.verified === true
        FE->>U: /dashboard руу чиглүүлэх
    end

%% ============================================================================
%% 4. EMAIL OTP PASSWORDLESS LOGIN FLOW
%% ============================================================================
%% Имэйл + OTP ашиглан нууц үггүй нэвтрэх:
%%   - 6 оронтой OTP код (10 мин хүчинтэй)
%%   - 5 удаагийн оролдлого хязгаар
%%   - 60 секундын cooldown дахин илгээхэд
%%   - SMTP-ээр имэйл илгээх (dev горимд console-д харуулна)
%% ============================================================================

sequenceDiagram
    participant U as Хэрэглэгч
    participant FE as Frontend
    participant BE as Backend
    participant R as Redis
    participant SMTP as SMTP Server
    participant DB as PostgreSQL

    U->>FE: Имэйл хаяг оруулах
    FE->>BE: POST /api/auth/email/send-otp {email}

    BE->>R: email_otp_cooldown:{email} шалгах
    alt Cooldown идэвхтэй
        BE-->>FE: 429 "60 секунд хүлээнэ үү"
    end

    BE->>BE: 6 оронтой OTP үүсгэх (crypto/rand)
    BE->>R: SET email_otp:{email} = "OTP:0" (TTL: 10 мин)
    BE->>R: SET email_otp_cooldown:{email} = "1" (TTL: 60 сек)

    alt Production горим
        BE->>SMTP: OTP имэйл илгээх (UTF-8 base64 encoding)
        SMTP-->>U: OTP код имэйлээр хүлээн авах
    else Development горим
        BE-->>FE: {otp: "123456"} шууд буцаах
    end

    U->>FE: OTP код оруулах
    FE->>BE: POST /api/auth/email/verify-otp {email, otp}

    BE->>R: GET email_otp:{email}
    BE->>BE: OTP шалгах + оролдлого тоолох

    alt OTP буруу (5-аас дээш оролдлого)
        BE->>R: DEL email_otp:{email}
        BE-->>FE: 401 "OTP хүчингүй"
    end

    alt OTP зөв
        BE->>R: DEL email_otp:{email}
        BE->>DB: FindOrCreateByEmail(email)
        BE->>DB: UPDATE last_login_at
        BE->>R: exchange_code хадгалах (60 сек)
        BE-->>FE: {exchange_code}
    end

    FE->>BE: POST /api/auth/exchange-token {code}
    BE-->>FE: {token, user}

    alt user.verified === false
        FE->>U: /register руу чиглүүлэх
    end

%% ============================================================================
%% 5. MANDATORY REG_NO VERIFICATION FLOW (ЗААВАЛ)
%% ============================================================================
%% Бүх шинэ хэрэглэгч reg_no баталгаажуулалт хийх ЁСТОЙ:
%%   - verified=false → /dashboard/** руу нэвтрэх боломжгүй
%%   - Dashboard layout → /register руу redirect
%%   - Consent page → /register руу redirect (oauth_redirect хадгална)
%%   - Email OTP login → /register руу redirect
%% ============================================================================

sequenceDiagram
    participant U as Хэрэглэгч
    participant FE as Frontend
    participant BE as Backend
    participant DB as PostgreSQL
    participant CORE as Gerege Core API

    Note over U,FE: Хэрэглэгч нэвтэрсэн, verified=false

    U->>FE: /dashboard руу очих оролдлого
    FE->>FE: dashboard/layout.tsx → user.verified шалгах
    FE->>U: 302 → /register руу чиглүүлэх

    U->>FE: /register хуудас
    U->>FE: Регистрийн дугаар оруулах (жишээ: УБ12345678)
    FE->>BE: POST /api/auth/verify {reg_no: "УБ12345678"}

    BE->>BE: reg_no → Latin ↔ Cyrillic хөрвүүлэх
    BE->>DB: SELECT * FROM citizens WHERE UPPER(reg_no) = ?

    alt Иргэн локал DB-д олдсон
        BE->>DB: BEGIN TRANSACTION
        BE->>DB: UPDATE users SET verified=true, citizen_id=X
        BE->>DB: INSERT INTO registry_verify_logs
        BE->>DB: COMMIT
    else Иргэн локал DB-д олдоогүй
        BE->>CORE: POST /api/user/find {reg_no}
        CORE-->>BE: Citizen data (нэр, хаяг, утас, ...)
        BE->>DB: INSERT INTO citizens (...) VALUES (...)
        BE->>DB: BEGIN TRANSACTION
        BE->>DB: UPDATE users SET verified=true, citizen_id=X
        BE->>DB: INSERT INTO registry_verify_logs
        BE->>DB: COMMIT
    end

    BE-->>FE: {user: {..., verified: true, verification_level: 2}}
    FE->>FE: authStore.setUser(user)
    FE->>U: /dashboard руу чиглүүлэх

    Note over U,FE: Одоо /dashboard/** болон /consent хуудсууд нээлттэй

%% ============================================================================
%% 6. OAUTH2 AUTHORIZATION SERVER FLOW (Third-Party Consent)
%% ============================================================================
%% Gerege SSO нь OAuth2 Authorization Server болж ажиллана:
%%   - Гуравдагч талын app → /api/oauth/authorize
%%   - Хэрэглэгч зөвшөөрөл → /consent хуудас
%%   - Authorization code → /api/oauth/token
%%   - Third-party JWT (1 цаг, reg_no/civil_id байхгүй)
%%   - PKCE дэмжлэгтэй (S256 / plain)
%% ============================================================================

sequenceDiagram
    participant CA as Client App<br/>(Гуравдагч тал)
    participant U as Хэрэглэгч
    participant FE as Frontend
    participant BE as Backend
    participant R as Redis
    participant DB as PostgreSQL

    CA->>U: Redirect → /api/oauth/authorize<br/>?client_id=X&redirect_uri=Y<br/>&response_type=code&scope=openid+profile<br/>&state=Z&code_challenge=C&code_challenge_method=S256

    U->>BE: GET /api/oauth/authorize
    BE->>DB: OAuth client шалгах (client_id, redirect_uri)
    BE->>BE: JWT token шалгах (cookie эсвэл header)

    alt Нэвтрээгүй бол
        BE->>U: 302 → Login page (/login?redirect=...)
    end

    alt user.verified === false
        BE->>FE: /consent → /register руу redirect
        FE->>FE: oauth_redirect = authorize URL хадгалах
        FE->>U: /register руу чиглүүлэх
        Note over U,FE: reg_no баталгаажуулалт хийсний дараа буцна
    end

    BE->>U: 302 → /consent?client_id=X&scope=openid+profile&...

    U->>FE: /consent хуудас (ямар мэдээлэл хуваалцахыг харуулна)
    U->>FE: "Зөвшөөрөх" дарах

    FE->>BE: GET /api/oauth/authorize?...&approve=true
    BE->>BE: Authorization code үүсгэх
    BE->>R: auth_code хадгалах (5 мин TTL)
    BE->>DB: user_grants бүртгэх
    BE->>U: 302 → redirect_uri?code=AUTH_CODE&state=Z

    U->>CA: Authorization code-тэй буцах

    CA->>BE: POST /api/oauth/token
    Note right of CA: {grant_type: authorization_code,<br/>code, client_id, client_secret,<br/>redirect_uri, code_verifier}

    BE->>R: auth_code шалгах + устгах
    BE->>DB: client_secret шалгах (bcrypt)

    alt PKCE ашигласан бол
        BE->>BE: code_verifier → SHA256 → code_challenge шалгах
    end

    BE->>BE: Third-Party JWT үүсгэх (1 цаг TTL)
    Note right of BE: JWT-д reg_no, civil_id БАЙХГҮЙ<br/>(ThirdPartyGeregeInfo ашиглана)

    BE-->>CA: {access_token, token_type: "Bearer", expires_in: 3600}

%% ============================================================================
%% 7. ACCOUNT LINKING FLOW (Олон Provider Холбох)
%% ============================================================================
%% Хэрэглэгч ижил email-ээр өөр provider-ээр нэвтрэхэд:
%%   - Аюулгүй байдлын үүднээс автоматаар холбохгүй
%%   - reg_no-оор таниулж баталгаажуулна
%%   - Redis-д pending_link 10 минут хадгална
%%   - Нэг удаагийн ашиглалт
%% ============================================================================

sequenceDiagram
    participant U as Хэрэглэгч
    participant FE as Frontend
    participant BE as Backend
    participant R as Redis
    participant DB as PostgreSQL

    Note over U: Google-ээр бүртгүүлсэн хэрэглэгч<br/>Apple-аар нэвтрэх оролдлого хийж байна

    U->>BE: Apple Login → callback
    BE->>DB: apple_sub-аар хайх → олдсонгүй
    BE->>DB: email-аар хайх → Google бүртгэлтэй олдлоо!

    BE->>R: SET pending_link:{gen_id} = JSON{<br/>  existing_user_id,<br/>  new_provider: "apple",<br/>  new_provider_id: apple_sub,<br/>  email<br/>} (TTL: 10 мин)

    BE->>U: 302 → /callback?pending_link=true&gen_id=XXX

    FE->>U: "Ижил имэйлтэй бүртгэл олдлоо.<br/>Бүртгэлүүдийг холбохын тулд<br/>регистрийн дугаараа оруулна уу"

    U->>FE: reg_no оруулах
    FE->>BE: POST /api/auth/confirm-link {gen_id, reg_no}

    BE->>R: GET pending_link:{gen_id}
    BE->>DB: Хэрэглэгчийн citizen мэдээлэл авах
    BE->>BE: reg_no таарч байгаа эсэх шалгах

    alt reg_no таарсан
        BE->>DB: UPDATE users SET apple_sub = ? WHERE id = ?
        BE->>R: DEL pending_link:{gen_id}
        BE->>DB: audit_log бүртгэх
        BE->>BE: JWT token үүсгэх
        BE->>R: exchange_code хадгалах
        BE-->>FE: {exchange_code}
    else reg_no таараагүй
        BE-->>FE: 400 "Регистрийн дугаар таарсангүй"
    end

%% ============================================================================
%% 8. DAN SSO VERIFICATION FLOW
%% ============================================================================
%% DAN (Цахим иргэний үнэмлэх) баталгаажуулалт:
%%   - https://sso.gov.mn/login руу redirect
%%   - Амжилттай бол verification_level = 4 (хамгийн өндөр)
%%   - reg_no автоматаар холбогдоно
%% ============================================================================

sequenceDiagram
    participant U as Хэрэглэгч
    participant FE as Frontend
    participant BE as Backend
    participant DAN as DAN SSO<br/>(sso.gov.mn)
    participant R as Redis
    participant DB as PostgreSQL

    U->>FE: "DAN-аар баталгаажуулах" дарах
    FE->>BE: GET /api/auth/dan

    BE->>R: state token хадгалах
    BE->>U: 302 → https://sso.gov.mn/login?client_id=X&redirect_uri=Y&state=Z

    U->>DAN: Цахим иргэний үнэмлэхээр нэвтрэх
    DAN->>BE: GET /api/auth/dan/authorized?reg_no=УБ12345678&state=Z

    BE->>R: state шалгах
    BE->>U: 302 → /callback?dan_success=true&reg_no=УБ12345678

    FE->>BE: GET /api/auth/dan/callback?reg_no=УБ12345678
    BE->>DB: LinkCitizen(userID, "УБ12345678")
    BE->>DB: UPDATE verification_level = 4
    BE->>DB: INSERT INTO dan_verification_logs
    BE-->>FE: {user: {..., verified: true, verification_level: 4}}

%% ============================================================================
%% 9. PHONE OTP VERIFICATION FLOW
%% ============================================================================
%% Утасны дугаар баталгаажуулалт:
%%   - Иргэний бүртгэлийн утасны дугаар руу OTP илгээх
%%   - verification_level = 3
%%   - Зөвхөн verified=true хэрэглэгчид (citizen холбогдсон байх ёстой)
%% ============================================================================

sequenceDiagram
    participant U as Хэрэглэгч
    participant FE as Frontend
    participant BE as Backend
    participant R as Redis
    participant DB as PostgreSQL

    U->>FE: Security хуудсанд "Утас баталгаажуулах" дарах
    FE->>BE: POST /api/auth/phone/send-otp (JWT required)

    BE->>DB: Хэрэглэгчийн citizen мэдээлэл авах
    BE->>BE: Утасны дугаар олох (citizen.phone_no)

    BE->>R: phone_otp_cooldown:{user_id} шалгах
    BE->>BE: 6 оронтой OTP үүсгэх
    BE->>R: SET phone_otp:{user_id} = "OTP:0" (TTL: 5 мин)
    BE->>R: SET phone_otp_cooldown:{user_id} = "1" (TTL: 60 сек)

    BE-->>FE: {phone: "99**5678"} (далд утасны дугаар)

    U->>FE: OTP оруулах
    FE->>BE: POST /api/auth/phone/verify-otp {otp}

    BE->>R: GET phone_otp:{user_id}
    BE->>BE: OTP шалгах (5 оролдлого хязгаар)

    alt OTP зөв
        BE->>DB: UPDATE users SET verification_level = 3
        BE-->>FE: {success: true}
    end

%% ============================================================================
%% 10. MFA AUTHENTICATION FLOW (Олон хүчин зүйлт баталгаажуулалт)
%% ============================================================================
%% Нэвтрэлтийн дараа MFA шалгалт хийх:
%%   - exchange-token → mfa_required: true + temp_token
%%   - Frontend → /mfa challenge хуудас
%%   - Хэрэглэгч аргаа сонгоно (TOTP, Passkey, Push, Recovery)
%%   - Амжилттай бол бүтэн JWT token олгоно
%% ============================================================================

sequenceDiagram
    participant U as Хэрэглэгч
    participant FE as Frontend
    participant BE as Backend
    participant R as Redis
    participant DB as PostgreSQL

    Note over U,FE: Нэвтрэлт амжилттай → MFA шаардлагатай

    FE->>BE: POST /api/auth/exchange-token {code}
    BE->>R: exchange_code шалгах + устгах
    BE->>DB: user.mfa_enabled шалгах
    BE->>BE: TempJWT үүсгэх (5 мин TTL, mfa_pending: true)
    BE-->>FE: {mfa_required: true, temp_token, mfa_methods: ["totp", "passkey"]}

    FE->>U: /mfa руу чиглүүлэх

    alt TOTP (Authenticator App) сонгосон
        U->>FE: 6 оронтой TOTP код оруулах
        FE->>BE: POST /api/auth/mfa/totp/validate {code} ⟨TempJWT⟩
        BE->>DB: user_totp.encrypted_secret авах
        BE->>BE: AES-256-GCM decrypt → TOTP шалгах
        alt TOTP зөв
            BE->>BE: Бүтэн JWT үүсгэх (24 цаг, mfa_verified: true)
            BE->>DB: mfa_audit_log бүртгэх (mfa_success)
            BE-->>FE: {token, user}
            FE->>U: /dashboard руу чиглүүлэх
        else TOTP буруу
            BE->>DB: mfa_audit_log бүртгэх (mfa_fail)
            BE-->>FE: 401 "TOTP код буруу"
        end

    else Passkey/FIDO2 сонгосон
        FE->>BE: POST /api/auth/mfa/passkey/auth/begin ⟨TempJWT⟩
        BE->>R: webauthn_auth:{gen_id} challenge хадгалах (5 мин)
        BE-->>FE: {publicKey: {challenge, allowCredentials, ...}}
        FE->>U: Passkey баталгаажуулалт (Touch ID, Face ID, Security Key)
        U-->>FE: WebAuthn assertion
        FE->>BE: POST /api/auth/mfa/passkey/auth/finish {assertion} ⟨TempJWT⟩
        BE->>R: webauthn_auth:{gen_id} challenge авах
        BE->>DB: webauthn_credentials шалгах
        BE->>BE: Бүтэн JWT үүсгэх (24 цаг, mfa_verified: true)
        BE->>DB: mfa_audit_log бүртгэх (mfa_success)
        BE-->>FE: {token, user}
        FE->>U: /dashboard руу чиглүүлэх

    else Push Notification сонгосон
        FE->>BE: POST /api/auth/push/challenge ⟨TempJWT⟩
        BE->>DB: user_devices-аас идэвхтэй төхөөрөмж хайх
        BE->>BE: Push notification илгээх
        BE-->>FE: {challenge_id}
        loop Хүлээх (30 сек timeout)
            FE->>BE: GET /api/auth/push/status/{challenge_id} ⟨TempJWT⟩
            BE-->>FE: {status: "pending" | "approved" | "denied"}
        end
        alt Зөвшөөрсөн
            BE->>BE: Бүтэн JWT үүсгэх (24 цаг, mfa_verified: true)
            BE-->>FE: {token, user}
            FE->>U: /dashboard руу чиглүүлэх
        end

    else Recovery Code сонгосон
        U->>FE: Нөөц код оруулах
        FE->>BE: POST /api/auth/mfa/recovery/validate {code} ⟨TempJWT⟩
        BE->>DB: mfa_recovery_codes-аас SHA-256 hash шалгах
        alt Код зөв + ашиглаагүй
            BE->>DB: UPDATE mfa_recovery_codes SET used=true
            BE->>BE: Бүтэн JWT үүсгэх (24 цаг, mfa_verified: true)
            BE->>DB: mfa_audit_log бүртгэх (recovery_used)
            BE-->>FE: {token, user, remaining_codes: N}
            FE->>U: /dashboard руу чиглүүлэх
        else Код буруу
            BE-->>FE: 401 "Нөөц код буруу"
        end
    end

%% ============================================================================
%% 11. MFA SETUP FLOW (TOTP тохиргоо)
%% ============================================================================
%% TOTP (Authenticator App) тохируулах:
%%   - /dashboard/security/mfa хуудсанд тохируулна
%%   - QR код скан хийх → баталгаажуулах → Recovery код олгох
%% ============================================================================

sequenceDiagram
    participant U as Хэрэглэгч
    participant FE as Frontend
    participant BE as Backend
    participant R as Redis
    participant DB as PostgreSQL

    U->>FE: /dashboard/security/mfa хуудас нээх
    FE->>BE: GET /api/auth/mfa/settings ⟨JWT⟩
    BE->>DB: user_mfa_settings авах
    BE-->>FE: {totp_enabled: false, passkey_enabled: false, ...}

    Note over U,FE: TOTP тохируулах

    U->>FE: "TOTP идэвхжүүлэх" дарах
    FE->>BE: POST /api/auth/mfa/totp/setup ⟨JWT⟩
    BE->>BE: TOTP secret үүсгэх (32 байт)
    BE->>R: SET mfa_totp_setup:{user_id} = {secret} (TTL: 10 мин)
    BE-->>FE: {qr_uri: "otpauth://totp/Gerege:user@email?secret=BASE32&issuer=Gerege", secret: "BASE32SECRET"}

    FE->>U: QR код харуулах + нууц түлхүүр
    U->>U: Authenticator app-аар QR скан хийх

    U->>FE: 6 оронтой код оруулах (баталгаажуулалт)
    FE->>BE: POST /api/auth/mfa/totp/verify-setup {code} ⟨JWT⟩
    BE->>R: GET mfa_totp_setup:{user_id}
    BE->>BE: TOTP код шалгах (secret-тэй тааруулах)

    alt Код зөв
        BE->>BE: AES-256-GCM-ээр secret шифрлэх
        BE->>DB: INSERT user_totp {encrypted_secret, iv, verified: true}
        BE->>DB: UPDATE user_mfa_settings SET totp_enabled=true
        BE->>DB: UPDATE users SET mfa_enabled=true
        BE->>BE: 12 ширхэг recovery код үүсгэх
        BE->>DB: INSERT mfa_recovery_codes (SHA-256 hash)
        BE->>R: DEL mfa_totp_setup:{user_id}
        BE->>DB: mfa_audit_log бүртгэх (totp_setup)
        BE-->>FE: {success: true, recovery_codes: ["XXXX-XXXX", ...]}
        FE->>U: Recovery кодуудыг хадгалахыг анхааруулах
    else Код буруу
        BE-->>FE: 400 "TOTP код буруу"
    end

    Note over U,FE: Passkey тохируулах

    U->>FE: "Passkey нэмэх" дарах
    FE->>BE: POST /api/auth/mfa/passkey/register/begin ⟨JWT⟩
    BE->>R: SET webauthn_reg:{gen_id} = {challenge, session} (TTL: 5 мин)
    BE-->>FE: {publicKey: {challenge, rp, user, pubKeyCredParams, ...}}

    FE->>U: Passkey бүртгэх (Touch ID, Face ID, Security Key)
    U-->>FE: WebAuthn attestation
    FE->>BE: POST /api/auth/mfa/passkey/register/finish {attestation} ⟨JWT⟩
    BE->>R: GET webauthn_reg:{gen_id}
    BE->>DB: INSERT webauthn_credentials {credential_id, public_key, name}
    BE->>DB: UPDATE user_mfa_settings SET passkey_enabled=true
    BE->>DB: mfa_audit_log бүртгэх (passkey_register)
    BE-->>FE: {success: true, credential: {id, name}}

