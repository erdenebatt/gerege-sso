%% 19. SECURITY ARCHITECTURE
%% ============================================================================

graph TB
    subgraph "Authentication Security"
        S1["Single-Use Exchange Codes<br/>60 сек TTL, нэг удаа ашиглана<br/>URL-д token харагдахаас сэргийлнэ"]
        S2["JWT Blacklisting<br/>Logout хийхэд jti → Redis<br/>Token expiry хүртэл хадгална"]
        S3["OTP Brute Force Protection<br/>5 оролдлого → автоматаар устгана<br/>60 сек cooldown"]
        S4["State Token Validation<br/>CSRF халдлагаас хамгаална<br/>OAuth state → Redis 10 мин"]
        S5["PKCE Support<br/>Authorization code interception-аас хамгаална<br/>S256 / plain method"]
    end

    subgraph "Data Security"
        D1["Third-Party Privacy<br/>reg_no, civil_id гуравдагч<br/>талд ХЭЗЭЭ Ч өгөхгүй"]
        D2["BCrypt Password Hashing<br/>OAuth client secret → bcrypt hash"]
        D3["HTTPOnly Cookies<br/>XSS-аас JWT хамгаална"]
        D4["Transaction Isolation<br/>LinkCitizen() → DB transaction<br/>Row-level locking"]
    end

    subgraph "MFA Security"
        MFA1["AES-256-GCM Encryption<br/>TOTP нууц түлхүүр шифрлэлт<br/>MFA_ENCRYPTION_KEY (32 bytes)"]
        MFA2["SHA-256 Hashed Recovery Codes<br/>Нөөц кодууд hash-лагдсан хадгалагдана<br/>Нэг удаагийн ашиглалт"]
        MFA3["WebAuthn/FIDO2<br/>Phishing-resistant баталгаажуулалт<br/>Public-key криптограф"]
        MFA4["TempJWT Scope Limitation<br/>MFA pending token → 5 мин TTL<br/>Зөвхөн /mfa/* endpoint-ууд руу"]
        MFA5["Backup Eligibility Tracking<br/>Нөөц код ашиглах боломжийг<br/>хянах (backup_eligible flag)"]
    end

    subgraph "Network Security"
        N1["Rate Limiting<br/>20 req/min per IP (auth endpoints)<br/>Redis token bucket"]
        N2["CORS Policy<br/>Frontend domain-аас л зөвшөөрнө"]
        N3["Security Headers<br/>CSP, X-Frame-Options<br/>HSTS, X-Content-Type-Options"]
        N4["TLS/SSL<br/>Nginx → HTTPS termination"]
    end

    subgraph "Audit Trail"
        AU1["audit_logs table<br/>Бүх үйлдлийг бүртгэнэ"]
        AU2["dan_verification_logs<br/>DAN баталгаажуулалт"]
        AU3["registry_verify_logs<br/>Регистрийн баталгаажуулалт"]
        AU4["Prometheus Metrics<br/>Login attempts, verification counts"]
        AU5["mfa_audit_log<br/>MFA setup, success, fail бүртгэл<br/>Арга тус бүрээр хянах"]
    end

