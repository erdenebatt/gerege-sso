        bigint civil_id "Иргэний ID"
        varchar first_name "Нэр"
        varchar last_name "Овог"
        varchar family_name "Ургийн овог"
        smallint gender "Хүйс"
        date birth_date "Төрсөн огноо"
        varchar phone_no "Утасны дугаар"
        varchar email "Имэйл"
        varchar aimag_city_code "Аймаг/Хот код"
        varchar aimag_city_name "Аймаг/Хот нэр"
        varchar sum_district_code "Сум/Дүүрэг код"
        varchar sum_district_name "Сум/Дүүрэг нэр"
        varchar bag_khoroo_code "Баг/Хороо код"
        varchar bag_khoroo_name "Баг/Хороо нэр"
        varchar street_name "Гудамж"
        varchar residence_address "Оршин суугаа хаяг"
        varchar ebarimt_tin "Е-баримт ТИН"
        timestamp deleted_date "Soft delete"
