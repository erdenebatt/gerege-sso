%% ============================================================================
%% 17. JWT TOKEN STRUCTURE
%% ============================================================================
%% Gerege SSO-ийн JWT token-ий бүтэц:
%%
%% Internal JWT (24 цаг):
%%   sub: gen_id (11 оронтой)
%%   email: user email
%%   mfa_verified: true/false (MFA баталгаажсан эсэх)
%%   gerege: {reg_no, first_name, family_name, last_name, birth_date, gender,
%%            verified, verification_level, name}
%%
%% Temp JWT (5 мин) - MFA хүлээж байгаа:
%%   sub: gen_id
%%   email: user email
%%   mfa_pending: true
%%   scope: "mfa_challenge" (хязгаарлагдмал эрх)
%%   ★ /api/auth/mfa/* endpoint-ууд руу л хандах боломжтой
%%
%% Third-Party JWT (1 цаг):
%%   sub: gen_id
%%   email: user email
%%   aud: client_id
%%   scope: "openid profile"
%%   gerege: {first_name, family_name, last_name, birth_date, gender,
%%            verified, verification_level, name}
%%   ★ reg_no, civil_id БАЙХГҮЙ (privacy)
%% ============================================================================

graph TB
    subgraph "Internal JWT (24h TTL)"
        IH["Header: {alg: HS256, typ: JWT}"]
        IP["Payload:<br/>sub: '10000000001' (gen_id)<br/>email: 'user@example.com'<br/>jti: 'uuid-v4'<br/>iat: timestamp<br/>exp: +24h<br/>mfa_verified: true<br/>gerege: {<br/>  reg_no: 'УБ12345678'<br/>  first_name: 'Бат'<br/>  family_name: 'Боржигон'<br/>  last_name: 'Дорж'<br/>  birth_date: '1990-01-01'<br/>  gender: 1<br/>  verified: true<br/>  verification_level: 2<br/>  name: 'Б.Дорж'<br/>}"]
        IS["Signature: HMAC-SHA256(secret)"]
    end

    subgraph "Temp JWT (5min TTL) - MFA Pending"
        TMH["Header: {alg: HS256, typ: JWT}"]
        TMP["Payload:<br/>sub: '10000000001' (gen_id)<br/>email: 'user@example.com'<br/>jti: 'uuid-v4'<br/>iat: timestamp<br/>exp: +5min<br/>mfa_pending: true<br/>scope: 'mfa_challenge'<br/>★ gerege claim БАЙХГҮЙ<br/>★ /api/auth/mfa/* endpoint-ууд руу л хандана"]
        TMS["Signature: HMAC-SHA256(secret)"]
    end

    subgraph "Third-Party JWT (1h TTL)"
        TH["Header: {alg: HS256, typ: JWT}"]
        TP["Payload:<br/>sub: '10000000001' (gen_id)<br/>email: 'user@example.com'<br/>aud: 'client_app_id'<br/>scope: 'openid profile'<br/>jti: 'uuid-v4'<br/>iat: timestamp<br/>exp: +1h<br/>gerege: {<br/>  ★ reg_no БАЙХГҮЙ<br/>  ★ civil_id БАЙХГҮЙ<br/>  first_name: 'Бат'<br/>  family_name: 'Боржигон'<br/>  last_name: 'Дорж'<br/>  birth_date: '1990-01-01'<br/>  gender: 1<br/>  verified: true<br/>  verification_level: 2<br/>  name: 'Б.Дорж'<br/>}"]
        TS2["Signature: HMAC-SHA256(secret)"]
    end

