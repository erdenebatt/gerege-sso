    users {
        bigserial id PK
        varchar gen_id UK "11 оронтой давтагдашгүй ID"
        varchar google_sub UK "Google account ID"
        varchar apple_sub UK "Apple account ID"
        varchar facebook_id UK "Facebook account ID"
        varchar twitter_id UK "Twitter account ID"
        varchar email "Имэйл хаяг"
        boolean email_verified "Имэйл баталгаажсан эсэх"
        varchar picture "Профайл зураг URL"
        bigint citizen_id FK "citizens.id → холбогдсон иргэн"
