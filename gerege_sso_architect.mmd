        boolean backup_eligible "Нөөц код ашиглах боломжтой эсэх"
        timestamp created_at
        timestamp updated_at
    }

    user_totp {
        bigserial id PK
        bigint user_id FK "users.id (unique)"
        varchar encrypted_secret "AES-256-GCM шифрлэгдсэн TOTP нууц"
        varchar encryption_iv "Шифрлэлтийн IV"
        boolean verified "Тохиргоо баталгаажсан эсэх"
        timestamp created_at
        timestamp updated_at
    }

    mfa_recovery_codes {
        bigserial id PK
        bigint user_id FK "users.id"
        varchar code_hash "SHA-256 hash"
        boolean used "Ашигласан эсэх"
        timestamp used_at "Ашигласан огноо"
        timestamp created_at
    }

    webauthn_credentials {
        bigserial id PK
        bigint user_id FK "users.id"
        varchar credential_id UK "WebAuthn credential ID"
        bytea public_key "Нийтийн түлхүүр"
        varchar name "Төхөөрөмжийн нэр"
        bigint sign_count "Гарын үсгийн тоолуур"
        varchar aaguid "Authenticator AAGUID"
        timestamp last_used_at "Сүүлд ашигласан"
        timestamp created_at
    }

    user_devices {
        bigserial id PK
        bigint user_id FK "users.id"
        varchar device_token "Push notification token"
        varchar platform "ios | android | web"
        varchar device_name "Төхөөрөмжийн нэр"
        boolean is_active "Идэвхтэй эсэх"
        timestamp last_used_at
        timestamp created_at
    }

    qr_login_sessions {
