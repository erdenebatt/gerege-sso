        varchar ip_address "IP хаяг"
        varchar user_agent "Browser мэдээлэл"
        timestamp expires_at "Дуусах хугацаа"
        timestamp created_at
    }

    audit_logs {
        bigserial id PK
        bigint user_id FK "users.id"
